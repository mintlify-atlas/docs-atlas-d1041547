  "keyFeatures": [
    "Multiple chaos experiment types (Pod, Network, IO, Stress, Time, Kernel, HTTP, DNS, JVM, Block, Cloud)",
    "Kubernetes-native with CRD-based architecture",
    "Web-based Dashboard for experiment management and monitoring",
    "Workflow orchestration for complex chaos scenarios",
    "Scheduled chaos experiments with cron-like scheduling",
    "Multi-cluster support for distributed chaos testing",
    "Status check integration for experiment validation",
    "Physical machine chaos injection support",
    "Fine-grained selector-based targeting",
    "Privileged DaemonSet for low-level system interference"
  ],
  "publicApiSurface": [
    "PodChaos CRD - Pod lifecycle fault injection",
    "NetworkChaos CRD - Network fault injection (delay, loss, corrupt, duplicate, partition)",
    "IOChaos CRD - I/O fault injection (delay, errno, attributes)",
    "StressChaos CRD - CPU and memory stress testing",
    "TimeChaos CRD - Clock skew simulation",
    "KernelChaos CRD - Kernel fault injection",
    "HTTPChaos CRD - HTTP request/response manipulation",
    "DNSChaos CRD - DNS fault injection",
    "JVMChaos CRD - JVM fault injection",
    "BlockChaos CRD - Block device fault injection",
    "AWSChaos CRD - AWS fault injection",
    "GCPChaos CRD - GCP fault injection",
    "AzureChaos CRD - Azure fault injection",
    "PhysicalMachineChaos CRD - Physical machine fault injection",
    "Workflow CRD - Orchestrate complex chaos scenarios",
    "Schedule CRD - Schedule chaos experiments",
    "StatusCheck CRD - Validate experiment outcomes",
    "Chaos Dashboard UI - Web interface for experiment management",
    "chaos-daemon gRPC API - Low-level chaos injection interface"
  ]
}
